# Application settings
APP_NAME="Reach Developments Station"
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# Database connection (PostgreSQL)
DATABASE_URL=postgresql://reach_admin:yourpassword@localhost:5432/reach_developments

# Logging
LOG_LEVEL=INFO

# API
API_V1_PREFIX=/api/v1

# Authentication (JWT)
SECRET_KEY=change-me-in-production-use-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
